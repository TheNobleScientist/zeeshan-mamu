rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /shows/{showId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
